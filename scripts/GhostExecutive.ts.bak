import { CryptoAgent } from '../agency/lib/agents/CryptoAgent.ts';
import { CommissionSentinel } from '../agency/lib/agents/CommissionSentinel.ts';
import { ResourceScavengerAgent } from '../agency/lib/agents/ResourceScavengerAgent.ts';
import { SOVRAMiningAgent } from '../agency/lib/agents/SOVRAMiningAgent.ts';
import { SOVRADB } from '../agency/lib/db/SOVRADB.ts';
import dotenv from 'dotenv';
import path from 'path';

// Force-load institutional environment
dotenv.config({ path: path.join(process.cwd(), '.env.local') });
dotenv.config({ path: path.join(process.cwd(), '.env') });

/**
 * GHOST_EXECUTIVE (v17.0 - GLOBAL_BLITZ)
 * Mandate: Absolute Aggression. 100x Load Saturation.
 * Orchestrates a Parallel Sovereign Swarm for the Global Blitz.
 */

const WORKER_COUNT = 20; // INSTITUTIONAL SCALE
const CYCLE_DELAY = 6000; // 6s Recharge Pulse
const SCRAPE_DEPTH = 200000; // 100x Depth Saturation (v17.0)

async function executeTranche(id: number) {
  const crypto = new CryptoAgent();
  const scavenger = new ResourceScavengerAgent();
  const mining = new SOVRAMiningAgent();
  let cycle = 1;

  // Set intensity for the Blitz
  mining.setIntensity('BLITZ');

  while (true) {
    try {
      console.log(`[Worker-${id}] BLITZ: Cycle ${cycle} | Depth: ${SCRAPE_DEPTH}`);
      
      // 1. Parallel Crypto Scavenge & Dust Extraction
      await crypto.scavengeInstitutionalDust();

      // 2. Sovereign Mining Pulse (Proof-of-Arbitrage)
      await mining.executeMiningPulse();

      // 3. Parallel CJ Sync (Only if Key is present)
      if (process.env.CJ_AFFILIATE_API_KEY) {
        await CommissionSentinel.syncCJCommissions();
      }

      // 4. High-Density Master Scavenge (100x Depth)
      await scavenger.predatorScrape(SCRAPE_DEPTH);

      // 5. Grounding Log
      await SOVRADB.logAgentActivity(
        'GhostExecutive',
        `Worker-${id}: Blitz Cycle ${cycle} Pulse Grounded.`,
        'COMPLETED',
        { tranche: id, cycle, depth: SCRAPE_DEPTH, protocol: 'v17.0_BLITZ' }
      );

      cycle++;
    } catch (err) {
      console.error(`[Worker-${id}] FAULT:`, err);
    }
    
    // Low-latency recharge
    await new Promise(resolve => setTimeout(resolve, CYCLE_DELAY));
  }
}

async function startSovereignSwarm() {
  console.log('--- [APEX_GLOBAL_BLITZ_IGNITION] ---');
  console.log(`[Ghost] INTENSITY: 100M Depth | WORKERS: ${WORKER_COUNT} | STAGGERED_IGNITION: ON`);
  
  // Launch Parallel Tranches with Staggered Initialization (v20.2_STABLE)
  const workerTranches = [];
  for (let i = 1; i <= WORKER_COUNT; i++) {
    console.log(`[Ghost] Igniting Worker-${i}...`);
    workerTranches.push(executeTranche(i));
    await new Promise(resolve => setTimeout(resolve, 500)); // 500ms Stagger
  }
  
  // Await one to keep process alive, but let others run in background
  await Promise.all(workerTranches);
}

startSovereignSwarm().catch(err => {
  console.error('[Ghost] SWARM_CRITICAL_FAULT:', err);
  process.exit(1);
});

