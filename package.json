{
  "name": "sovra-command",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "build-apps": "bash scripts/build-apps.sh",
    "harden": "npx tsx src/scripts/InfrastructureHardening.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "export KMP_DUPLICATE_LIB_OK=TRUE && concurrently \"npm run dev\" \"electron .\"",
    "electron:build": "next build && electron-builder",
    "ghost:start": "export KMP_DUPLICATE_LIB_OK=TRUE && export TIER=365B && export PATH=\"/opt/homebrew/bin:$PATH\" && nohup npx tsx scripts/GhostExecutive.ts > ghost_output.log 2>&1 &",
    "tony": "npx tsx src/scripts/tony_pulse.ts",
    "govern": "npx tsx -e \"import { SovereignApex } from './sovra/core/apex/SovereignApex.ts'; new SovereignApex().executeTranche({ name: 'GOVERNANCE_BLITZ', layer: 'L14_APEX', action: 'STRATEGIC_REIGN', maSTScore: 0.01 })\"",
    "apex": "npx tsx -e \"import { SovereignApex } from './sovra/core/apex/SovereignApex.ts'; new SovereignApex().executeTranche({ name: 'APEX_COMMAND_OVERRIDE', layer: 'L14_APEX', action: 'EXECUTIVE_MANDATE', maSTScore: 0.01 })\"",
    "work": "npx tsx src/scripts/LiveFireMandate.ts",
    "livefire": "npx tsx src/scripts/LiveFireMandate.ts",
    "blast": "npx tsx src/scripts/MorningBlast.ts",
    "scour": "npx tsx src/scripts/GitHubScour.ts",
    "scavenge": "export PATH=\"/opt/homebrew/bin:$PATH\" && npx tsx -e \"import { ResourceScavengerAgent } from './agency/lib/agents/ResourceScavengerAgent.ts'; new ResourceScavengerAgent().scavenge()\"",
    "server:start": "export PATH=\"/opt/homebrew/bin:$PATH\" && npx tsx agency/server/index.ts",
    "server:dev": "export PATH=\"/opt/homebrew/bin:$PATH\" && npx tsx --watch agency/server/index.ts",
    "ignite:all": "concurrently -c \"cyan.bold,magenta.bold,yellow.bold\" -n \"SIA_EDGE,SIA_CORE,SIA_SWARM\" \"pnpm dev\" \"pnpm server:dev\" \"export PATH=\\\"/opt/homebrew/bin:$PATH\\\" && npx tsx agency/MannixExec.ts\""
  },
